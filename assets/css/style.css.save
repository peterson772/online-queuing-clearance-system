/* ===== USJM Awesome Theme ===== */
:root {
    --usjm-blue: ;
    --usjm-gold: #ffd700;
    --usjm-dark: #002b5c;
    --usjm-light: #f0f5ff;
}

body {
    font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
    background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
    margin: 0;
    min-height: 100vh;
}

/* Hero Section */
.hero-section {
    background: linear-gradient(145deg, var(--usjm-dark) 0%, var(--usjm-blue) 100%);
    color: white;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    animation: rotate 30s linear infinite;
}

@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.hero-logo {
    max-height: 100px;
    margin-bottom: 20px;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
}

.brand-wrapper h1 {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    line-height: 1.2;
}

.hero-description {
    font-size: 1.2rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    color: rgba(255,255,255,0.9);
}

/* Feature Cards */
.feature-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(255,255,255,0.3);
}

.feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
}

.icon-box {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--usjm-blue), var(--usjm-dark));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: white;
    box-shadow: 0 10px 20px rgba(0, 71, 171, 0.3);
}

.feature-card h3 {
    color: var(--usjm-dark);
    font-weight: 700;
}

.feature-card p {
    color: #555;
}

/* Buttons */
.btn-primary {
    background-color: var(--usjm-blue);
    border-color: var(--usjm-blue);
    padding: 12px 24px;
    font-weight: 600;
    border-radius: 50px;
    transition: all 0.3s;
}

.btn-primary:hover {
    background-color: var(--usjm-dark);
    border-color: var(--usjm-dark);
    transform: scale(1.02);
}

.btn-outline-primary {
    color: var(--usjm-blue);
    border-color: var(--usjm-blue);
    border-radius: 50px;
    font-weight: 600;
}

.btn-outline-primary:hover {
    background-color: var(--usjm-blue);
    color: white;
}

.btn-success {
    background-color: #28a745;
    border-color: #28a745;
    border-radius: 50px;
    font-weight: 600;
    padding: 12px 24px;
}

.btn-success:hover {
    background-color: #218838;
    transform: scale(1.02);
}

/* Responsive Adjustments */
@media (max-width: 768px) {
    .hero-section {
        text-align: center;
        padding: 60px 20px;
    }
    
    .brand-wrapper h1 {
        font-size: 2rem;
    }
    
    .hero-logo {
        max-height: 70px;
    }
}
